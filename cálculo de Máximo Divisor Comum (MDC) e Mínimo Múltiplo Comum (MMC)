// função de expomnencial de inteiros (para uso no domínio do problema, base >= 0, expoente >= 0)
int64_t powint(int64_t base, int64_t exp) {
    int64_t r = 1;
    while (exp > 0) {
        if (exp & 1) r *= base;
        base *= base;
        exp >>= 1;
    }
    return r;
}

